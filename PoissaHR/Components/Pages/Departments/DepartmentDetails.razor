@using PoissaHR.Application.Services.DepartmentService
@using PoissaHR.Shared.Dto

@inject IDepartmentService DepartmentService
@inject NavigationManager Navigation

@page "/departments/{Id:guid}"

@if (department == null)
{
    <p>Ladataan osaston tietoja...</p>
}
else
{
    <MudGrid Spacing="3">

        <!-- Basic Info -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Style="min-height: 13rem;">
                <MudText Typo="Typo.h6">@department.Name</MudText>
                <br />
                <MudText>@department.CompanyName</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4" Style="min-height: 13rem;">
                <MudText Typo="Typo.h6">Nykyiset työntekijät</MudText>
                <MudTable Items="@department.CurrentEmployees">
                    <HeaderContent>
                        <MudTh>Nimi</MudTh>
                        <MudTh>Titteli</MudTh>
                        <MudTh>Työsuhde</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="employee">
                        @if (department.CurrentEmployees != null)
                        {
                            <MudTd>@employee.EmployeeName</MudTd>
                            <MudTd>@employee.JobTitle</MudTd>
                            <MudTd>@employee.Type</MudTd>
                            <MudTd>@employee.Status</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => GoToEmployee(employee.EmployeeId))" />
                            </MudTd>
                        }
                        else
                        {
                            <MudTd ColSpan="4">Ei työntekijöitä</MudTd>
                        }
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <!-- Edit Info -->

        <MudItem xs="12">
            <MudText Typo="Typo.h6" Class="d-flex align-center">
                Muokkaa tietoja
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               OnClick="@(() => Navigation.NavigateTo($"/departments/{department.Id}/edit"))" />
            </MudText>
        </MudItem>

    </MudGrid>

@code {
    [Parameter]
    public Guid Id { get; set; }

    [Parameter]
    public Guid EmployeeId { get; set; }

    private DepartmentDto? department;

    protected override async Task OnInitializedAsync()
    {
        department = await DepartmentService.GetDepartmentByIdAsync(Id);
    }

    private void GoToEmployee(Guid employeeId) => Navigation.NavigateTo($"/employees/{employeeId}");
}
}