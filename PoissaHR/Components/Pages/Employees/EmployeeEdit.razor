@using PoissaHR.Application.Services.EmployeeService
@using PoissaHR.Shared.Dto

@inject IEmployeeService EmployeeService
@inject NavigationManager Navigation

@page "/employees/{Id:guid}/edit-info"

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5" GutterBottom="true">
        Muokkaa työntekijän tietoja
    </MudText>

    <MudForm @ref="_form">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField Label="Etunimi"
                              @bind-Value="model.FirstName"
                              Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Sukunimi"
                              @bind-Value="model.LastName"
                              Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Sähköposti"
                              @bind-Value="model.Email"
                              Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Label="Puhelinnumero"
                              @bind-Value="model.Phone"
                              Required="true" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Spacing="2" Class="mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="Save">
                Tallenna
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       OnClick="Cancel">
                Peruuta
            </MudButton>
        </MudStack>
    </MudForm>
</MudPaper>


@code {
    [Parameter]
    public Guid Id { get; set; }

    private EmployeeEditDto model = new();
    private MudForm? _form;

    protected override async Task OnInitializedAsync()
    {
        var employee = await EmployeeService.GetEmployeeForEditAsync(Id);

        if (employee == null)
        {
            Navigation.NavigateTo("/employees");
            return;
        }

        model = employee;
    }

    private async Task Save()
    {
        if (_form == null)
            return;

        await _form.Validate();

        if (!_form.IsValid)
            return;

        await EmployeeService.UpdateEmployeeAsync(model);

        Navigation.NavigateTo($"/employees/{model.Id}");
    }

    private void Cancel()
    {
        Navigation.NavigateTo($"/employees/{Id}");
    }
}
