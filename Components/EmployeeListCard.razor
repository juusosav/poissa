@using PoissaHR.Domain.Entities
@using PoissaHR.Application.Services.EmployeeService
@using PoissaHR.Shared.Dto

@inject IEmployeeService EmployeeService

<MudTable Items="@Employees" Hover="true" Bordered="true" Striped="true">
    <HeaderContent>
        <MudTh>Etunimi</MudTh>
        <MudTh>Sukunimi</MudTh>
        <MudTh>Osasto</MudTh>
    </HeaderContent>
    <RowTemplate Context="employee">
        <MudTd>@employee.FirstName</MudTd>
        <MudTd>@employee.LastName</MudTd>
        <MudTd>@employee.Department.Name</MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Parameter]
    public List<EmployeeDto> Employees { get; set; } = new();
}
